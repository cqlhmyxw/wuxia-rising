ot;:15253675}" class="community_post is_reply has_vote_column"><div class="post_grid"><div class="post_votes"><a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" title="Vote up" data-register_action="community_vote" class="vote_up_btn vote_btn"><svg aria-hidden role="img" class="svgicon icon_vote_up" viewBox="0 0 24 24" width="20" height="20" version="1.1"><polygon points="2 18 12 6 22 18" /></svg></a> <a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" title="Vote down" data-register_action="community_vote" class="vote_down_btn vote_btn"><svg aria-hidden role="img" class="svgicon icon_vote_down" viewBox="0 0 24 24" width="20" height="20" version="1.1"><polygon points="2 6 12 18 22 6" /></svg></a></div><a class="avatar_container" href="https://itch.io/profile/gelezo43"><div class="post_avatar" style="background-image: url(/static/images/frog-gold.png)"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/gelezo43">gelezo43</a></span><span class="post_date" title="2026-01-11 12:50:05"><a href="https://itch.io/post/15253675">175 days ago</a></span><span class="vote_counts"></span></div><div class="post_content"><div class="post_body user_formatted" dir="auto"><p>Of course!</p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" data-register_action="community_reply" class="post_action reply_btn">Reply</a></div></div></div></div></div></div><div id="post-14017235" data-post="{&quot;user_id&quot;:7588474,&quot;id&quot;:14017235}" class="community_post has_vote_column"><div class="post_grid"><div class="post_votes"><a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" title="Vote up" data-register_action="community_vote" class="vote_up_btn vote_btn"><svg aria-hidden role="img" class="svgicon icon_vote_up" viewBox="0 0 24 24" width="20" height="20" version="1.1"><polygon points="2 18 12 6 22 18" /></svg></a> <a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" title="Vote down" data-register_action="community_vote" class="vote_down_btn vote_btn"><svg aria-hidden role="img" class="svgicon icon_vote_down" viewBox="0 0 24 24" width="20" height="20" version="1.1"><polygon points="2 6 12 18 22 6" /></svg></a></div><a class="avatar_container" href="https://itch.io/profile/the-hacker-of-lava"><div class="post_avatar" style="background-image: url(/static/images/frog-blue.png)"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/the-hacker-of-lava">The Hacker Of Lava</a></span><span class="post_date" title="2025-09-02 17:09:30"><a href="https://itch.io/post/14017235">306 days ago</a></span><span class="vote_counts"><span class="upvotes">(+1)</span></span></div><div class="post_content"><div class="post_body user_formatted" dir="auto"><p>Am i dumb or is there no down and front base in this asset ? (i&#x27;m not good in explaining)<img src="https://img.itch.zone/aW1nLzIzMDE1OTEzLnBuZw==/original/IOKc9J.png" loading="lazy"></p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" data-register_action="community_reply" class="post_action reply_btn">Reply</a></div></div></div></div><div id="post-14005680" data-post="{&quot;user_id&quot;:8070987,&quot;id&quot;:14005680}" class="community_post has_vote_column"><div class="post_grid"><div class="post_votes"><a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" title="Vote up" data-register_action="community_vote" class="vote_up_btn vote_btn"><svg aria-hidden role="img" class="svgicon icon_vote_up" viewBox="0 0 24 24" width="20" height="20" version="1.1"><polygon points="2 18 12 6 22 18" /></svg></a> <a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" title="Vote down" data-register_action="community_vote" class="vote_down_btn vote_btn"><svg aria-hidden role="img" class="svgicon icon_vote_down" viewBox="0 0 24 24" width="20" height="20" version="1.1"><polygon points="2 6 12 18 22 6" /></svg></a></div><a class="avatar_container" href="https://itch.io/profile/gamingvillager"><div class="post_avatar" style="background-image: url(/static/images/frog-red.png)"></div></a><div class="post_header"><span class="post_author"><a href="https://itch.io/profile/gamingvillager">GamingVillager</a></span><span class="post_date" title="2025-09-02 01:56:18"><a href="https://itch.io/post/14005680">307 days ago</a></span><span class="vote_counts"><span class="downvotes">(-2)</span></span></div><div class="post_content"><div class="post_body user_formatted" dir="auto"><p>Hey I used your sprites for my recent game project. It&#x27;s my most popular game yet so I really appreciate your hard work helping me along with it.<br><a href="https://gx.games/games/64tuf3/no-hit-run/" referrerpolicy="origin" rel="nofollow noopener">https://gx.games/games/64tuf3/no-hit-run/</a></p></div><div class="post_footer"><a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" data-register_action="community_reply" class="post_action reply_btn">Reply</a></div></div></div></div><div id="post-13639525" data-post="{&quot;user_id&quot;:8574786,&quot;id&quot;:13639525}" class="community_post has_replies has_vote_column"><div class="post_grid"><div class="post_votes"><a href="https://itch.io/login?return_to=https%3A%2F%2F0x72.itch.io%2Fdungeontileset-ii&amp;intent=community" title="Vote up" data-register_action="community_vote" class="vote_up_btn vote_btn"><svg aria-hidden role="img" class="svgicon icon_vote_up" viewBox="0 0 24 24" width="20" height="20" version="1.1"><